{
  "name": "stemcut",
  "version": "1.3.0",
  "description": "StemCut - Isolez chaque instrument de vos morceaux",
  "main": "electron/main.js",
  "scripts": {
    "electron:dev": "ELECTRON_RUN_AS_NODE= NODE_ENV=development electron .",
    "build:frontend": "cd frontend && npm run build && cp -r .next/static .next/standalone/.next/static && ([ -d public ] && cp -r public .next/standalone/public || true)",
    "build:backend": "bash scripts/build-backend-mac.sh",
    "build:backend:x64": "bash scripts/build-backend-mac-x64.sh",
    "electron:build": "npm run build:frontend && npm run build:backend && electron-builder --mac --arch arm64",
    "electron:build:x64": "npm run build:frontend && npm run build:backend:x64 && npx electron-builder --mac dmg --arch x64",
    "electron:build:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1",
    "publish": "bash scripts/publish-release.sh"
  },
  "build": {
    "appId": "com.stemcut.app",
    "productName": "StemCut",
    "directories": {
      "output": "dist"
    },
    "afterSign": "scripts/afterSign.js",
    "mac": {
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.music",
      "target": ["dmg"],
      "identity": null
    },
    "win": {
      "icon": "electron/icons/icon.png",
      "target": ["nsis"]
    },
    "nsis": {
      "runAfterFinish": true
    },
    "files": [
      "electron/main.js",
      "electron/preload.js",
      "electron/icons/**"
    ],
    "extraResources": [
      {
        "from": "dist-backend/stemcut-backend",
        "to": "backend-bin",
        "filter": ["**"]
      },
      {
        "from": "frontend/.next/standalone",
        "to": "frontend-standalone"
      }
    ]
  },
  "devDependencies": {
    "electron": "^41.4.0",
    "electron-builder": "^24.0.0"
  }
}
