{
  "name": "stemcut",
  "version": "1.0.0",
  "description": "StemCut - Isolez chaque instrument de vos morceaux",
  "main": "electron/main.js",
  "scripts": {
    "electron:dev": "ELECTRON_RUN_AS_NODE= NODE_ENV=development electron .",
    "build:frontend": "cd frontend && npm run build && cp -r .next/static .next/standalone/.next/static && ([ -d public ] && cp -r public .next/standalone/public || true)",
    "electron:build": "npm run build:frontend && ln -sfn \"$(pwd)/.venv\" _venv && electron-builder; rm -f _venv",
    "electron:build:x64": "bash scripts/build-x64.sh"
  },
  "build": {
    "appId": "com.stemcut.app",
    "productName": "StemCut",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.music",
      "target": ["dmg"]
    },
    "win": {
      "icon": "electron/icons/icon.png",
      "target": ["nsis"]
    },
    "nsis": {
      "closeApplications": true
    },
    "files": [
      "electron/main.js",
      "electron/preload.js",
      "electron/icons/**"
    ],
    "extraResources": [
      {
        "from": "_venv",
        "to": ".venv",
        "filter": ["**"]
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*.py", "requirements.txt"]
      },
      {
        "from": "frontend/.next/standalone",
        "to": "frontend-standalone"
      }
    ]
  },
  "devDependencies": {
    "electron": "^41.4.0",
    "electron-builder": "^24.0.0"
  }
}
